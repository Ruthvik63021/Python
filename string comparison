#Using for loop:

s="AAACCCBAABB"
result = ""
count = 1
for i in range(len(s)):
    if i+1<len(s) and s[i]==s[i+1]:
        count+=1
    else:
        result+=s[i]+str(count)
        count=1 
print("Compressed string:", result)

#Using while loop:

s="AAACCCBAABB"
i=0
result=""
while i<len(s):
    count=1
    while i+1<len(s) and s[i]==s[i+1]:
        count+=1
        i+=1
    result+=s[i]+str(count)
    i+=1
print("Compressed string:", result)
